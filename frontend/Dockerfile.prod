# ===========================================================================
# Production frontend — multi-stage build
# Stage 1: Build the React/Vite app
# Stage 2: Serve static assets via nginx with security headers
# ===========================================================================

# ---- Stage 1: Build ----
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci --ignore-scripts

COPY . .
ENV NODE_ENV=production
RUN npm run build

# ---- Stage 2: nginx ----
FROM nginx:1.27-alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# SGA3-M5: Copy nginx template — CSP origins are templated via envsubst at startup
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

# Copy built assets from the build stage
COPY --from=build /app/dist /usr/share/nginx/html

# Default CSP origins (localhost wildcards for self-hosted deployments)
ENV CSP_CONNECT_ORIGINS="'self' http://localhost:* ws://localhost:* wss://localhost:* https://api.coingecko.com"
ENV CSP_IMG_ORIGINS="'self' data: blob: http://localhost:* https://api.coingecko.com"
ENV CSP_MEDIA_ORIGINS="'self' blob: http://localhost:*"

# Run as non-root
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid && \
    chown -R nginx:nginx /etc/nginx/conf.d

USER nginx

EXPOSE 80

# SGA3-M5: envsubst replaces ${CSP_*} placeholders in the template,
# then nginx starts normally. The nginx:alpine image auto-processes
# templates in /etc/nginx/templates/ on startup.
CMD ["nginx", "-g", "daemon off;"]
