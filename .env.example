# Environment Variables for Money Agents

# =============================================================================
# API Keys - External Services
# =============================================================================
# Provide API keys for the LLM providers you want to use.
# The system will automatically use available providers with failover.
# Default priority: glm (cheapest) → claude (quality) → openai (fallback)

# OpenAI API Key (for GPT-4o, o1, DALL-E, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude Opus 4, Sonnet 4, Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Z.ai API Key (For GLM-4.7 via Zhipu AI - has FREE flash models!)
Z_AI_API_KEY=your_zai_api_key_here

# ElevenLabs API Key (for voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Serper API Key (for web search)
SERPER_API_KEY=your_serper_api_key_here

# Serper Clone Configuration (optional - for local self-hosted Serper-compatible API)
# If you're running Serper Clone (https://github.com/paulscode/searxng-serper-bridge),
# set USE_SERPER_CLONE=true and provide the URL to your instance.
# Serper Clone uses a self-signed certificate, so SSL verification is disabled.
# Cost tracking is disabled when using Serper Clone (it's free!).
USE_SERPER_CLONE=false
SERPER_CLONE_URL=

# Whether to add Suno AI music generation to the tools catalog
USE_SUNO=true

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Provider priority order (comma-separated). Uses first available provider.
# Default: glm,claude,openai,ollama (cheapest first, GLM has free flash tier, Ollama last)
# LLM_PROVIDER_PRIORITY=glm,claude,openai,ollama

# Force a specific provider (ignores priority, fails if unavailable)
# LLM_FORCE_PROVIDER=claude

# =============================================================================
# Ollama Configuration (Local LLM)
# =============================================================================
# Enable Ollama as an LLM provider (requires Ollama running locally or remotely)
# Ollama is always tried LAST due to rate limiting / low concurrency
USE_OLLAMA=false

# Ollama API endpoint
# - For local dev without Docker: http://localhost:11434
# - For Docker containers: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Model tiers for Ollama: fast,reasoning,quality (comma-separated)
# These models must be pulled in Ollama first: ollama pull <model>
OLLAMA_MODEL_TIERS=hf.co/mradermacher/Nanbeige4.1-3B-GGUF:Q8_0,mistral-nemo:12b,glm-4.7-flash:latest

# Context window sizes per tier (comma-separated, matching tier order)
OLLAMA_CONTEXT_LENGTHS=262144,65536,8192

# Max concurrent requests to Ollama (default: 1 - Ollama is heavily rate-limited)
OLLAMA_MAX_CONCURRENT=1

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL password (auto-generated on first run if left as default)
POSTGRES_PASSWORD=CHANGE_ME_generate_a_secure_password

# Host-side port for PostgreSQL (mapped to container port 5432)
# Change this if port 5433 is already in use on your machine.
# If changed, update the port in DATABASE_URL below as well.
POSTGRES_PORT=5433

# PostgreSQL Connection String (password is kept in sync with POSTGRES_PASSWORD automatically)
DATABASE_URL=postgresql+asyncpg://money_agents:CHANGE_ME_generate_a_secure_password@localhost:5433/money_agents
# GAP-21: For remote PostgreSQL deployments (not Docker-local), append ?ssl=require:
#   DATABASE_URL=postgresql+asyncpg://money_agents:PASSWORD@remote-host:5432/money_agents?ssl=require

# Host-side port for Redis (default: 6379)
REDIS_PORT=6379

# Redis Connection String
# Note: Password must match REDIS_PASSWORD used in docker-compose.yml
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_generate_a_secure_password

# Host-side port for the backend API (default: 8000)
BACKEND_PORT=8000

# Flower monitoring UI credentials
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_generate_a_secure_password

# =============================================================================
# Internal Service Authentication
# =============================================================================
# These keys protect communication between the backend and host-side services.
# They are auto-generated on first run by start.py — do NOT leave them empty in production.

# API key for GPU/CPU tool services (ACE-Step, Z-Image, Qwen3-TTS, etc.)
# Shared by all host-side tool services via scripts/gpu_service_security.py middleware.
GPU_SERVICE_API_KEY=

# API key for the service manager (handles VRAM eviction restarts)
SERVICE_MANAGER_API_KEY=

# Port for the host-side service manager (default: 9100)
SERVICE_MANAGER_PORT=9100

# Service manager URL (auto-derived from SERVICE_MANAGER_PORT by start.py)
# Only override this if the service manager runs on a different host.
SERVICE_MANAGER_URL=http://host.docker.internal:9100

# =============================================================================
# Application Configuration
# =============================================================================

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_super_secret_key_here_change_this_in_production

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Environment (production or development)
# Production: enforces secure SECRET_KEY, enables HSTS, hides test endpoints.
# Development: relaxes SECRET_KEY checks, exposes test endpoints.
ENVIRONMENT=production

# Host operating system (auto-detected by start.py)
HOST_OS=linux

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent Configurations
OPPORTUNITY_SCOUT_FREQUENCY=6h
PROPOSAL_MIN_SCORE=0.7
CAMPAIGN_MAX_CONCURRENT=5
MONITOR_CHECK_FREQUENCY=5m

# =============================================================================
# Resource Management
# =============================================================================

# GPU Configuration
USE_GPU=true

# GPU Affinity — assign each service to specific GPU(s) by index (comma-separated)
# Use "nvidia-smi -L" to see GPU indices on your system.
# Examples: "0" (single GPU), "0,1" (two GPUs), "1" (second GPU only)
GPU_OLLAMA=0
GPU_ACESTEP=0
GPU_QWEN3_TTS=0
GPU_ZIMAGE=0
GPU_SEEDVR2=0
GPU_CANARY_STT=0
GPU_AUDIOSR=0
GPU_LTX_VIDEO=0

# ComfyUI Tools (auto-populated by start.py — generally don't edit manually)
# Format: name|display_name|port|comfyui_url|gpu_indices separated by semicolons
# Example: ltx-2|LTX-2 Video|8190|http://localhost:8188|0;z-image-turbo|Z-Image Turbo|8191|http://localhost:8188|0,1
COMFYUI_TOOLS=

# Job Queue Configuration
MAX_QUEUE_SIZE=100
DEFAULT_JOB_PRIORITY=5

# =============================================================================
# ACE-Step Local Music Generation
# =============================================================================
# ACE-Step is a local AI music generation model that produces commercial-grade
# songs with lyrics, supports 50+ languages, covers, and style transfer.
# It runs locally - free and unlimited! Requires ~5GB disk space for models.
# GitHub: https://github.com/ace-step/ACE-Step-1.5

# Enable ACE-Step (requires GPU with ≥4GB VRAM recommended, or CPU mode)
USE_ACESTEP=false

# ACE-Step API server URL (runs on host, accessed via docker network)
ACESTEP_API_URL=http://host.docker.internal:8001

# ACE-Step API port (for the local server)
ACESTEP_API_PORT=8001

# ACE-Step API key (for authentication, auto-generated if not set)
ACESTEP_API_KEY=

# ACE-Step DiT model: turbo, base, xl-turbo, xl-base, xl-sft
# Note: The server auto-selects the best LM model based on GPU VRAM.
# - turbo: 2B DiT, 8 steps, fast (~3.6s), ~13 GB VRAM
# - base: 2B DiT, 45 steps, higher diversity, ~12 GB VRAM
# - xl-turbo: 4B DiT, 8 steps, fast + richer audio than 2B, ~17 GB VRAM
# - xl-base: 4B DiT, 50 steps, high diversity, all tasks (extract/lego/complete), ~17 GB VRAM
# - xl-sft: 4B DiT, 50 steps, best audio quality (SFT), standard tasks only, ~17 GB VRAM
# XL models require >=20 GB VRAM (>=24 GB recommended with LM)
ACESTEP_MODEL=turbo

# Auto-start ACE-Step server when Money Agents starts
ACESTEP_AUTO_START=true

# ACE-Step model download source: auto, huggingface, modelscope
ACESTEP_DOWNLOAD_SOURCE=auto

# =============================================================================
# Qwen3-TTS Local Voice Generation
# =============================================================================
# Qwen3-TTS is a local AI text-to-speech model by Alibaba with voice cloning,
# 9 built-in speakers, and voice design from text descriptions.
# Multi-lingual: Chinese, English, Japanese, Korean.
# It runs locally - free and unlimited! Requires ~3-6GB disk space for models.
# GitHub: https://github.com/QwenLM/Qwen3-TTS

# Enable Qwen3-TTS (requires GPU with ≥4GB VRAM recommended)
USE_QWEN3_TTS=false

# Qwen3-TTS API server URL (runs on host, accessed via docker network)
QWEN3_TTS_API_URL=http://host.docker.internal:8002

# Qwen3-TTS API port (for the local server)
QWEN3_TTS_API_PORT=8002

# Qwen3-TTS model tier: auto, full (1.7B), lite (0.6B)
# - full: 1.7B model, all features: custom voice, voice clone, voice design (~8GB VRAM)
# - lite: 0.6B model, voice clone only (~4GB VRAM)
# - auto: Auto-detect based on GPU VRAM
QWEN3_TTS_TIER=auto

# Auto-start Qwen3-TTS server when Money Agents starts
QWEN3_TTS_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
QWEN3_TTS_IDLE_TIMEOUT=300

# =============================================================================
# Z-Image Local Image Generation
# =============================================================================
# Z-Image is a 6B parameter Diffusion Transformer (DiT) model from Tongyi/Alibaba
# that generates high-quality images from text prompts.
# The Turbo variant uses 8-step distilled inference for fast generation.
# It runs locally - free and unlimited! Requires ~12GB disk space for model weights.
# GitHub: https://github.com/Tongyi-MAI/Z-Image

# Enable Z-Image (requires GPU with ≥16GB VRAM recommended)
USE_ZIMAGE=false

# Z-Image API server URL (runs on host, accessed via docker network)
ZIMAGE_API_URL=http://host.docker.internal:8003

# Z-Image API port (for the local server)
ZIMAGE_API_PORT=8003

# Z-Image model variant: turbo (default)
ZIMAGE_MODEL=turbo

# Auto-start Z-Image server when Money Agents starts
ZIMAGE_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
ZIMAGE_IDLE_TIMEOUT=300

# =============================================================================
# SeedVR2 Local Image & Video Upscaler
# =============================================================================
# SeedVR2 is a one-step diffusion-based super-resolution model from ByteDance
# that upscales images and videos to higher resolutions while adding realistic detail.
# Supports 3B and 7B parameter DiT models with FP8/FP16 precision options.
# It runs locally - free and unlimited! Requires ~4GB disk space for model weights (3B FP8).
# GitHub: https://github.com/numz/ComfyUI-SeedVR2_VideoUpscaler

# Enable SeedVR2 (requires GPU with ≥8GB VRAM recommended for 3B FP8)
USE_SEEDVR2=false

# SeedVR2 API server URL (runs on host, accessed via docker network)
SEEDVR2_API_URL=http://host.docker.internal:8004

# SeedVR2 API port (for the local server)
SEEDVR2_API_PORT=8004

# SeedVR2 DiT model: filename of the model weights
# Options:
#   seedvr2_ema_3b_fp8_e4m3fn.safetensors  (~4GB, 8-12GB VRAM)  - Recommended
#   seedvr2_ema_3b_fp16.safetensors        (~7GB, 12-16GB VRAM)
#   seedvr2_ema_7b_fp8_e4m3fn.safetensors  (~9GB, 14-18GB VRAM)
#   seedvr2_ema_7b_fp16.safetensors        (~17GB, 20-24GB VRAM)
SEEDVR2_MODEL=seedvr2_ema_3b_fp8_e4m3fn.safetensors

# Auto-start SeedVR2 server when Money Agents starts
SEEDVR2_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
SEEDVR2_IDLE_TIMEOUT=300

# =============================================================================
# Canary-STT Local Speech-to-Text
# =============================================================================
# NVIDIA Canary-Qwen-2.5B is a state-of-the-art English ASR model with
# 2.5B parameters, processing at 418x realtime on GPU.
# Built on SALM architecture with FastConformer + Qwen3-1.7B decoder.
# It runs locally - free and unlimited! Requires ~5GB disk space for model weights.
# HuggingFace: https://huggingface.co/nvidia/canary-qwen-2.5b

# Enable Canary-STT (requires GPU with ≥8GB VRAM recommended)
USE_CANARY_STT=false

# Canary-STT API server URL (runs on host, accessed via docker network)
CANARY_STT_API_URL=http://host.docker.internal:8005

# Canary-STT API port (for the local server)
CANARY_STT_API_PORT=8005

# Auto-start Canary-STT server when Money Agents starts
CANARY_STT_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
CANARY_STT_IDLE_TIMEOUT=300

# =============================================================================
# AudioSR Local Audio Super-Resolution
# =============================================================================
# AudioSR is a versatile audio super-resolution model that upscales any audio
# (music, speech, environmental) to 48kHz high-fidelity output using latent diffusion.
# Works on all types of audio and all input sampling rates.
# It runs locally - free and unlimited! Requires ~4-8GB VRAM.
# GitHub: https://github.com/haoheliu/versatile_audio_super_resolution

# Enable AudioSR (requires GPU with ≥8GB VRAM recommended)
USE_AUDIOSR=false

# AudioSR API server URL (runs on host, accessed via docker network)
AUDIOSR_API_URL=http://host.docker.internal:8007

# AudioSR API port (for the local server)
AUDIOSR_API_PORT=8007

# AudioSR model variant: basic (all audio types) or speech (speech-optimized)
AUDIOSR_MODEL=basic

# Auto-start AudioSR server when Money Agents starts
AUDIOSR_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
AUDIOSR_IDLE_TIMEOUT=300

# =============================================================================
# Media Toolkit (FFmpeg-based Media Composition)
# =============================================================================
# The Media Toolkit enables agents to split, combine, and mix media files
# using FFmpeg. Operations include extracting audio, combining video + audio,
# mixing multiple audio tracks, creating slideshows, trimming, and more.
# CPU-only — no GPU required. Runs locally - free and unlimited!

# Enable Media Toolkit
USE_MEDIA_TOOLKIT=false

# Media Toolkit API server URL (runs on host, accessed via docker network)
MEDIA_TOOLKIT_API_URL=http://host.docker.internal:8008

# Media Toolkit API port (for the local server)
MEDIA_TOOLKIT_API_PORT=8008

# Auto-start Media Toolkit server when Money Agents starts
MEDIA_TOOLKIT_AUTO_START=true

# =============================================================================
# Real-ESRGAN CPU (CPU-only Image & Video Upscaling)
# =============================================================================
# Real-ESRGAN CPU upscaler provides image and video upscaling using
# Real-ESRGAN neural network models running entirely on CPU.
# No GPU required — designed as a fallback when GPU is busy or unavailable.
# WARNING: CPU upscaling is significantly slower than GPU upscaling.
# For GPU-accelerated upscaling, use SeedVR2 instead.
# GitHub: https://github.com/xinntao/Real-ESRGAN

# Enable Real-ESRGAN CPU upscaler
USE_REALESRGAN_CPU=false

# Real-ESRGAN CPU API server URL (runs on host, accessed via docker network)
REALESRGAN_CPU_API_URL=http://host.docker.internal:8009

# Real-ESRGAN CPU API port (for the local server)
REALESRGAN_CPU_API_PORT=8009

# Model name — options:
#   realesr-animevideov3       (anime/video optimized, fastest, default)
#   realesrgan-x4plus          (general-purpose, best quality for photos)
#   realesrnet-x4plus          (general-purpose, faster)
#   realesrgan-x4plus-anime    (anime images)
REALESRGAN_CPU_MODEL=realesr-animevideov3

# Auto-start Real-ESRGAN CPU server when Money Agents starts
REALESRGAN_CPU_AUTO_START=true

# =============================================================================
# Docling Document Parser (CPU-only Document Parsing & Conversion)
# =============================================================================
# Docling is an open-source document parser by IBM that converts PDF, DOCX,
# PPTX, HTML, images, and more into structured Markdown or JSON output.
# Features advanced table recognition (TableFormer) and OCR (EasyOCR).
# CPU-only — no GPU required. Runs locally - free and unlimited!
# GitHub: https://github.com/docling-project/docling

# Enable Docling Document Parser
USE_DOCLING=false

# Docling API server URL (runs on host, accessed via docker network)
DOCLING_API_URL=http://host.docker.internal:8010

# Docling API port (for the local server)
DOCLING_API_PORT=8010

# Auto-start Docling server when Money Agents starts
DOCLING_AUTO_START=true

# =============================================================================
# LTX-2 Video (Local Text-to-Video Generation)
# =============================================================================
# LTX-2.3 is a 22B parameter distilled DiT model from Lightricks that generates
# videos with synchronized audio from text prompts. Uses FP8 quantization with
# Gemma 3 12B text encoder (layer streaming) and two-stage distilled inference (8+4 steps).
# It runs locally - free and unlimited! Requires ~80GB disk space for model weights.
# GitHub: https://github.com/Lightricks/LTX-2

# Enable LTX-2 Video (requires GPU with ≥24GB VRAM — RTX 3090 or better)
USE_LTX_VIDEO=false

# LTX-2 Video API server URL (runs on host, accessed via docker network)
LTX_VIDEO_API_URL=http://host.docker.internal:8006

# LTX-2 Video API port (for the local server)
LTX_VIDEO_API_PORT=8006

# Auto-start LTX-2 Video server when Money Agents starts
LTX_VIDEO_AUTO_START=true

# Idle timeout in seconds - unload model from GPU after this many seconds of inactivity
# to free VRAM for other tasks. Set to 0 to never unload.
LTX_VIDEO_IDLE_TIMEOUT=300

# Path to model weights directory (relative to project root or absolute)
# Expected files: ltx-2.3-22b-distilled.safetensors, ltx-2.3-spatial-upscaler-x2-1.1.safetensors,
# gemma-3-12b/ (directory with Gemma text encoder)
LTX_VIDEO_MODEL_DIR=models/ltx-2

# =============================================================================
# Bitcoin / LND Lightning Node
# =============================================================================
# Connect to your LND node to give agents access to Bitcoin on-chain and
# Lightning Network balances, payments, and invoices.
# The system uses LND's REST API for all communications.
#
# Tor (.onion) Support:
# Start9 and other privacy-focused nodes expose LND via Tor hidden services.
# LND always serves HTTPS (even over Tor) with a self-signed certificate.
# TLS verification is auto-disabled for .onion addresses.
# A Tor SOCKS5 proxy container auto-starts when .onion URLs are detected.

# Enable LND wallet integration
USE_LND=false

# LND REST API URL (always https:// — LND serves HTTPS even over Tor)
# Examples:
#   Local node:    https://localhost:8080
#   Remote node:   https://mynode.local:8080
#   Umbrel:        https://umbrel.local:8080
#   Docker:        https://host.docker.internal:8080
#   Start9 (Tor):  https://abc123...xyz.onion:8080
#   Start9 (LAN):  https://abc123...xyz.local:8080
# NOTE: .local (mDNS) addresses are auto-resolved by start.py for Docker.
#       Tor .onion addresses are auto-proxied via the tor-proxy container.
LND_REST_URL=https://host.docker.internal:8080

# Hex-encoded admin macaroon for LND authentication
# Generate with: xxd -ps -c 10000 ~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
# Or use the macaroon from your node's connection settings
LND_MACAROON_HEX=

# TLS certificate verification (false recommended for self-signed LND certs)
# Auto-disabled for Tor .onion addresses
LND_TLS_VERIFY=false

# Optional: base64-encoded TLS certificate content
# Generate with: base64 -w 0 ~/.lnd/tls.cert
# Only needed if LND_TLS_VERIFY=true
LND_TLS_CERT=

# Tor SOCKS5 proxy for .onion addresses (auto-configured by start.py)
# The tor-proxy Docker container provides this. Only needed for .onion URLs.
# Default when using tor-proxy container: socks5://tor-proxy:9050
LND_TOR_PROXY=

# Mempool Explorer URL for clickable transaction links and fee estimates
# Use https://mempool.space for public mainnet, or your own instance
# For Start9: use your Mempool Explorer's .local URL (e.g., https://abc123...def.local)
# NOTE: .local (mDNS) hostnames are auto-resolved to IPs by start.py so Docker
#       containers can reach them. If fees show as unavailable, verify the URL is
#       reachable from your host machine and re-run start.py to refresh DNS resolution.
LND_MEMPOOL_URL=https://mempool.space

# Global payment safety limit (satoshis). 0 = no limit.
# Prevents any single payment above this amount. Default: 1,000,000 sats (~$300-600).
LND_MAX_PAYMENT_SATS=10000

# =============================================================================
# Nostr (Decentralized Social Protocol)
# =============================================================================
# Give agents the ability to publish content, build audiences, and earn
# Bitcoin tips (zaps) on the Nostr decentralized social network.
# Each agent can create its own Nostr identity with a unique keypair.

# Enable Nostr tool for agents
USE_NOSTR=false

# Default relays for publishing and reading (comma-separated)
NOSTR_DEFAULT_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.snort.social

# Rate limits per identity (protects against spam / relay bans)
NOSTR_POST_RATE_LIMIT_HOUR=10
NOSTR_POST_RATE_LIMIT_DAY=50

# Relay timeout settings (seconds)
NOSTR_RELAY_TIMEOUT=5
NOSTR_RELAY_CONNECT_TIMEOUT=3

# Default Lightning Address for agent profiles (enables receiving zaps)
# All agent identities will include this as their lud16 in Nostr profiles.
# Recommended: Use Alby Hub connected to your LND node for a free @getalby.com address.
# Example: you@getalby.com
NOSTR_LIGHTNING_ADDRESS=

# Docker Compose profiles (auto-managed by start.py)
# Comma-separated list. "tor" activates the tor-proxy container.
COMPOSE_PROFILES=

# =============================================================================
# Dev Sandbox (Isolated Agent Development Environment)
# =============================================================================
# Ephemeral Docker containers for agents to run code, build apps, and test.
# Requires Docker socket access (auto-configured by docker-compose).
# No GPU required — runs on CPU only.

# Enable Dev Sandbox (default: true — Docker is already required by the platform)
USE_DEV_SANDBOX=true

# Default Docker image for new sandboxes
DEV_SANDBOX_DEFAULT_IMAGE=python:3.12-slim

# Maximum number of concurrent sandboxes
DEV_SANDBOX_MAX_CONCURRENT=5

# Default and maximum sandbox timeout (seconds)
# Sandboxes are automatically destroyed after their timeout expires.
DEV_SANDBOX_DEFAULT_TIMEOUT=300
DEV_SANDBOX_MAX_TIMEOUT=1800

# Default and maximum memory limit per sandbox
DEV_SANDBOX_DEFAULT_MEMORY=512m
DEV_SANDBOX_MAX_MEMORY=2g

# Default network access (false = no internet, true = internet allowed)
# Can be overridden per sandbox at creation time.
DEV_SANDBOX_NETWORK_ACCESS=false

# =============================================================================
# Logging
# =============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path
LOG_FILE_PATH=/var/log/money-agents/app.log

# =============================================================================
# Frontend Configuration (if needed by backend)
# =============================================================================

FRONTEND_URL=http://localhost:3000

# =============================================================================
# Optional Services
# =============================================================================

# Sentry (Error Tracking) - Optional
# SENTRY_DSN=your_sentry_dsn_here

# Prometheus (Metrics) - Optional
# PROMETHEUS_ENABLED=false

# =============================================================================
# Development Tools
# =============================================================================

# Enable API documentation (set to true for development only, SA2-17)
ENABLE_DOCS=false

# Enable debug mode (never true in production)
DEBUG=false
